  ldflags = -Wl,--wrap=exp -Wl,--wrap=exp2 -Wl,--wrap=expf -Wl,--wrap=fcntl64 -Wl,--wrap=gettid -Wl,--wrap=log -Wl,--wrap=log2 -Wl,--wrap=log2f -Wl,--wrap=logf -Wl,--wrap=pow -Wl,--wrap=powf -static-libstdc++ -static-libgcc -Wl,--eh-frame-hdr --ld-path=/usr/lib/llvm21/bin/ld.lld -fno-pic -Wl,-no-pie -Wl,--as-needed -Wl,-z,stack-size=12800000 -Wl,--compress-debug-sections=zlib -Wl,-z,lazy -Wl,-z,norelro -Wl,-O2 -Wl,--gdb-index -Wl,-z,combreloc -Wl,--sort-section=name -Wl,--hash-style=both -Wl,--build-id=sha1 -Wl,--gc-sections -Wl,-icf=safe -Wl,-Map=/home/fanmi/workspace/bun/build/release/bun-profile.linker-map -Bsymbolics-functions -rdynamic -Wl,--dynamic-list=/home/fanmi/workspace/bun/src/symbols.dyn -Wl,--version-script=/home/fanmi/workspace/bun/src/linker.lds -lc -lpthread -ldl -l:libatomic.a

rule strip
  command = /usr/bin/strip $stripflags $in -o $out
  description = strip $out

build bun: strip bun-profile
  stripflags = --strip-all --strip-debug --discard-all -R .eh_frame -R .gcc_except_table

rule smoke_test
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts check --console sh -c '( env BUN_DEBUG_QUIET_LOGS=1 /home/fanmi/workspace/bun/build/release/bun-profile --revision ) && touch $out'
  description = bun-profile --revision
  pool = console

build bun-profile.smoke-test-passed: smoke_test bun-profile

build check: phony bun-profile.smoke-test-passed

default bun check
