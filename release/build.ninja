# Generated by scripts/build/configure.ts
# DO NOT EDIT — changes will be overwritten on next configure

ninja_required_version = 1.9

pool dep
  depth = 4

pool bun_install
  depth = 1

rule mkdir_stamp
  command = mkdir -p $dir && touch $out
  description = mkdir $dir

build obj/.dir: mkdir_stamp
  dir = obj

build pch/.dir: mkdir_stamp
  dir = pch

rule cxx
  command = /usr/bin/ccache /usr/lib/llvm21/bin/clang++ $cxxflags -MMD -MT $out -MF $out.d -c $in -o $out
  description = cxx $out
  depfile = $out.d
  deps = gcc

rule cxx_pch
  command = /usr/bin/ccache /usr/lib/llvm21/bin/clang++ $cxxflags -Winvalid-pch -Xclang -include-pch -Xclang $pch_file -Xclang -include -Xclang $pch_header -MMD -MT $out -MF $out.d -c $in -o $out
  description = cxx $out
  depfile = $out.d
  deps = gcc

rule cc
  command = /usr/bin/ccache /usr/lib/llvm21/bin/clang $cflags -MMD -MT $out -MF $out.d -c $in -o $out
  description = cc $out
  depfile = $out.d
  deps = gcc

rule pch
  command = /usr/bin/ccache /usr/lib/llvm21/bin/clang++ $cxxflags -Winvalid-pch -fpch-instantiate-templates -Xclang -emit-pch -Xclang -include -Xclang $pch_header -x c++-header -MD -MT $out -MF $out.d -c $in -o $out
  description = pch $out
  depfile = $out.d
  deps = gcc

rule link
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts link --console /usr/lib/llvm21/bin/clang++ @$out.rsp $ldflags -o $out
  description = link $out
  pool = console
  rspfile = $out.rsp
  rspfile_content = $in_newline

rule ar
  command = /usr/bin/llvm-ar rcs $out @$out.rsp
  description = ar $out
  rspfile = $out.rsp
  rspfile_content = $in_newline

rule dep_fetch
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts $name /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/fetch-cli.ts dep $name $repo $commit $dest $cache $patches
  description = fetch $name
  restat = 1
  pool = dep

rule dep_fetch_prebuilt
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts $name /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/fetch-cli.ts prebuilt $name $url $dest $identity $rm_paths
  description = fetch $name (prebuilt)
  restat = 1
  pool = dep

rule dep_configure
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts $name --cwd=$srcdir /usr/bin/cmake --fresh -B$builddir $args
  description = cmake $name
  restat = 1
  pool = dep

rule dep_build
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts $name /usr/bin/cmake --build $builddir --config $buildtype $targets
  description = build $name
  restat = 1
  pool = dep

rule dep_cargo
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts $name --cwd=$manifestdir $env /home/fanmi/.cargo/bin/cargo build $args
  description = cargo $name
  restat = 1
  pool = dep

rule dep_prebuild
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts $name --cwd=$cwd $cmd
  description = prebuild $name
  restat = 1
  pool = dep

rule codegen
  command = cd $cwd && /home/fanmi/.bun/bin/bun $args
  description = gen $desc
  restat = 1

rule esbuild
  command = cd $cwd && /home/fanmi/workspace/bun/node_modules/.bin/esbuild $args
  description = esbuild $desc

rule bun_install
  command = cd $dir && /home/fanmi/.bun/bin/bun install --frozen-lockfile && touch $stamp
  description = install $dir
  restat = 1
  pool = bun_install

build codegen/.dir: mkdir_stamp
  dir = codegen

build stamps/.dir: mkdir_stamp
  dir = stamps

rule zig_fetch
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts zig /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/fetch-cli.ts zig $url $dest $commit
  description = zig download compiler
  restat = 1

rule zig_build
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build/stream.ts zig --console --env=ZIG_LOCAL_CACHE_DIR=$zig_local_cache --env=ZIG_GLOBAL_CACHE_DIR=$zig_global_cache $zig build $step $args
  description = zig $step → $out
  restat = 1
  pool = console

rule regen
  command = /home/fanmi/.bun/bin/bun /home/fanmi/workspace/bun/scripts/build.ts --config-file=$in
  description = reconfigure
  restat = 1
  generator = 1
  pool = console

